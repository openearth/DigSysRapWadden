@book{Stolte2001,
abstract = {The increase of harmful algal blooms (HABs) in Europe in the past decades as a result of anthropogenic activities is of growing concern of the community. Effects on the ecosystem level are known to occur, but there are also direct and indirect effects on the health and edibility of wild and cultured fish and shellfish. The socio-economic impact of HAB events in Europe is poorly known, due to lack of a central administration of HAB events and accounting frameworks to translate these events into socio-economic measures. The poor knowledge on socio-economic impacts of HABs hampers the justification of measures to prevent, manage and mitigate the negative effects of HABs. Such measures include for example scientific research on formation and fate of HABs and their toxins or harmful effects, monitoring programs, nutrient discharge reduction efforts, and the control of algal toxins in (shell)fish meant for human consumption. ECOHARM aims to complete a database of HAB events and their socio-economic effects to pinpoint which areas are sensitive to socio-economic losses due to HABs. ECOHARM further aims at integrating existing knowledge on biological and geographical aspects of HABs in European waters and at improving understanding and quantitative assessment of the socio-economic impacts of HABs. The project will be carried out in three overlapping phases: (i) inventory, (ii) case modelling, and (iii) general accounting framework and socio-economic risk assessment. No information is readily available for the estimation of economical effects of HABs. There is neither a clear overview nor database of HAB outbreaks potentially causing economic damage. The project will therefore start with a survey of HAB outbreaks in Europe during the past ten years with the help of literature databases and (inter)national organisations dealing with marine environmental problems and seafood control. Potential economic impacts of each bloom event will be classified according to the blooming species, duration of the bloom and geographical details. On the basis of this classification, specific events will be selected for a detailed socio-economic analysis. These case studies will help to define key factors for socio-economic effect calculation. Finally, a generalised accounting framework will be developed which is capable of providing a complete overview of costs of HAB in European waters in the last 10 years. The accounting framework is based on the use of environmental valuation methods. For health costs involved the concept of Quality Adjusted Life Years (QALYs) will be used. This index measures the effect of HABs on lost lives and the extent to which affected individuals suffer from intoxication. The accounting framework is complemented by a risk assessment to calculate expected damages of future HAB events and probabilities of disaster. ECOHARM will produce a database of HAB events with potential negative socio-economic effects in Europe over the last decade. A general accounting framework will be developed and used to estimate the total socio-economic effects of HABs in Europe in the past. The framework will be available to assess future socio-economic impacts of HABs in marine European waters.},
author = {Stolte, W and Scatasta, S and Graneli, E and Weikard, H P and {Van Ierland}, E},
booktitle = {American Journal of Pharmaceutical Education},
file = {:C$\backslash$:/Users/stolte/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Stolte et al. - 2001 - ECOHARM The socio-economic impact of harmful algal blooms in european marine waters.pdf:pdf},
isbn = {7141903720},
issn = {15536467},
keywords = {waddenzee},
mendeley-tags = {waddenzee},
number = {10},
pages = {100},
pmid = {21436911},
title = {{ECOHARM : The socio-economic impact of harmful algal blooms in european marine waters}},
url = {http://www.pubmedcentral.nih.gov/articlerender.fcgi?artid=3058461{\&}tool=pmcentrez{\&}rendertype=abstract},
volume = {EVK3-CT-20},
year = {2001}
}
