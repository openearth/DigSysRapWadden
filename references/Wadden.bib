file = {:C$\backslash$:/Users/stolte/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/de Boer et al. - 2012 - OpenEarth using Google Earth as outreach for NCK's data.pdf:pdf},
isbn = {9789036533423},
keywords = {waddenzee},
mendeley-tags = {waddenzee},
pages = {97--103},
publisher = {University of Twente, Department of Water Engineering {\&} Management},
title = {{OpenEarth: using Google Earth as outreach for NCK's data}},
