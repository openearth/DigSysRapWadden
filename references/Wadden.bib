file = {:C$\backslash$:/Users/stolte/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Jonge, de Jonge - 2000 - Importance of temporal and spatial scales in applying biological and physical process knowledge in coastal mana.pdf:pdf;:C$\backslash$:/Users/stolte/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/De Jonge - 2000 - Importance of temporal and spatial scales in applying biological and physical process knowledge in coastal management,.pdf:pdf},
