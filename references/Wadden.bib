abstract = {De Amerikaanse zwaardschede (Ensis directus) is een exoot in de Nederlandse$\backslash$nwateren. De$\backslash$n$\backslash$nsoort is in 1979 voor het eerst in Europa aangetroffen en heeft zich$\backslash$nsindsdien sterk ontwikkeld.$\backslash$n$\backslash$nThans is de Amerikaanse zwaardschede verreweg de belangrijkste mesheft$\backslash$nsoort in Nederland$\backslash$n$\backslash$nen vanwege de hoge biomassa is de soort een belangrijk onderdeel van$\backslash$nhet mariene$\backslash$n$\backslash$necosysteem geworden. Dit ecoprofiel van mesheften is opgesteld om$\backslash$nmeer inzicht te krijgen in$\backslash$n$\backslash$nde ecologie van mesheften en hun rol in het ecosysteem.$\backslash$n$\backslash$nMesheften zijn langgerekte schelpdieren die vertikaal ingegraven zitten$\backslash$nin de zeebodem. Ze$\backslash$n$\backslash$nkomen zowel voor in het sublitoraal (tot 15 a 30 meter) als in de$\backslash$nlage delen van het litoraal. Bij$\backslash$n$\backslash$nonraad kunnen ze zich met behulp van hun sterke voet snel dieper (tot$\backslash$nmeer dan 30 cm) het$\backslash$n$\backslash$nsediment inwerken. Ook kunnen ze het sediment ontvluchten en zwemmen$\backslash$nnaar geschiktere$\backslash$n$\backslash$nlocaties. Mesheften hebben gescheiden geslachten, en door het relatief$\backslash$nlange larvale stadium$\backslash$n$\backslash$n(2 � 4 weken) kunnen ze zich met de waterbeweging over grote afstanden$\backslash$nverplaatsen.$\backslash$n$\backslash$nDe bestanden van mesheften in de Voordelta waren de laatste jaren$\backslash$n(2002 tot en met 2005)$\backslash$n$\backslash$naanzienlijk hoger dan de voorgaande jaren. In het gebied in de Voordelta$\backslash$ndat in 2004 intensief is$\backslash$n$\backslash$nbemonsterd in het kader van met Monitoring- en Evaluatieprogramma$\backslash$nMaasvlakte 2 is het totale$\backslash$n$\backslash$nbestand geschat op 71 miljard individuen met een totale biomassa van$\backslash$n493 miljoen kg$\backslash$n$\backslash$nversgewicht (oppervlakte onderzoeksgebied is 68 duizend ha).$\backslash$n$\backslash$nDe veelal hoge biomassa�s die er de laatste jaren worden gevonden$\backslash$nin de Voordelta vormt een$\backslash$n$\backslash$npotenti�le voedselbron voor predatoren als vissen en vogels. Ondanks$\backslash$nde grote scherpe$\backslash$n$\backslash$nschelpen kunnen vogels als eidereenden en zwarte zee-eenden mesheften$\backslash$neten. Omdat het niet$\backslash$n$\backslash$neenvoudig is de mesheften die zich met hun voet kunnen verankeren$\backslash$nuit de zeebodem te halen$\backslash$n$\backslash$nis het mogelijk dat ze voornamelijk schelpen eten die uit het sediment$\backslash$nzijn geraakt. Ook$\backslash$n$\backslash$nscholeksters en meeuwen doen zich vaak te goed aan mesheften die vaak$\backslash$nmassaal op de$\backslash$n$\backslash$nstranden zijn aangespoeld.$\backslash$n$\backslash$nHet mesheften bestand in de Nederlandse kustwateren wordt op dit moment$\backslash$ndoor 4 vissers$\backslash$n$\backslash$nbevist. Drie vissers zijn actief in de Voordelta en een visser vist$\backslash$nin de Kustzone boven de$\backslash$n$\backslash$nWaddeneilanden. De effecten van de ensisvisserij op het bestand en$\backslash$noverige bodembewoners$\backslash$n$\backslash$nzijn relatief beperkt door de gebruikte technieken en de geringe inspanning.},
address = {IJmuiden},
author = {Wijsman, J W M and Kesteloo, J J and Craeymeersch, J E},
file = {:C$\backslash$:/Users/stolte/AppData/Local/Mendeley Ltd./Mendeley Desktop/Downloaded/Kesteloo, Craeymeersch - 2006 - Ecologie , visserij en monitoring van mesheften in de Voordelta.pdf:pdf},
institution = {RIVO},
keywords = {Eastern Scheldt,Grevelingen,Oosterschelde,Westerschelde,waddenzee},
mendeley-tags = {Eastern Scheldt,Grevelingen,Oosterschelde,Westerschelde,waddenzee},
number = {C0009/06},
