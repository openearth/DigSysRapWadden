@Article{Dias2012,
  abstract = {The ecological traits of piscivorous marine birds have been acknowledged to reflect ecosystem changes. We used the great cormorant as our indicator species in the Minho estuary (NW-Iberian Peninsula, Europe) to assess the temporal variation of their diet and the factors that could influence that variation. Pellets were collected in a night roost, located centrally in the estuary, during two consecutive wintering periods (2005-2006 and 2006-2007). The great cormorant population showed a high degree of feeding plasticity and most of the variation in cormorants' diet was attributed to river discharge fluctuations. Overall, during periods of increased river discharge, marine and marine opportunistic species disappeared from diet, whereas freshwater species increased. The cormorants in this study were using a roost in the middle of the estuary, so they were facing a changing food base over time, in accordance to variation in river discharges. The birds did not keep their diet constant but rather took what became locally available, notwithstanding their broad foraging range. Therefore, we suggest that great cormorants may be considered good samplers of local ichthyofauna and thus, temporal variation in the local prey can be followed by analyzing cormorants' diet. {\textcopyright} 2012 Elsevier B.V.},
  author = {Ester Dias and Pedro Morais and Mardik Leopold and Joana Campos and Carlos Antunes},
  doi = {10.1016/j.seares.2012.06.012},
  file = {:C$\backslash$:/Users/stolte/OneDrive - Stichting Deltares/Documents/mendeleyDocuments/Dias et al. - 2012 - Natural born indicators Great cormorant Phalacrocorax carbo (Aves Phalacrocoracidae) as monitors of river discharge.pdf:pdf},
  isbn = {1385-1101},
  issn = {13851101},
  journal = {Journal of Sea Research},
  keywords = {Cormorant,Diet,Ecological Indicators,Estuary,River Discharge,Seabird},
  pages = {101--108},
  publisher = {Elsevier B.V.},
  title = {{Natural born indicators: Great cormorant Phalacrocorax carbo (Aves: Phalacrocoracidae) as monitors of river discharge influence on estuarine ichthyofauna}},
  url = {http://dx.doi.org/10.1016/j.seares.2012.06.012},
  volume = {73},
  year = {2012},
}

